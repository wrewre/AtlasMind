# ============================================================
# Mind Map Generator — Environment Configuration
# ============================================================

# ── FREE Cloud API Keys ───────────────────────────────────────
# Gemini: https://aistudio.google.com/apikey  (15 RPM free)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq:   https://console.groq.com/keys       (30 RPM free)
GROQ_API_KEY=your_groq_api_key_here

# Model selection for Groq
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (Local — Zero Rate Limits) ────────────────────────
# Runs inside Docker, no API key needed.
# llama3.2   = 2GB download, good quality, runs on CPU
# llama3.2:1b = 1GB download, faster but less accurate
# phi3       = 2.3GB, very good for structured JSON output
OLLAMA_MODEL=llama3.2

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Neo4j (optional) ─────────────────────────────────────────
NEO4J_ENABLED=false

# ── Database (Neon PostgreSQL) ────────────────────────────────
# Sign up free at https://neon.tech/ and paste your connection string here
# Format: postgres://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://your_user:your_password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── JWT Auth ──────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production-use-a-256-bit-secret

# ── Chunking — larger chunks = fewer LLM calls ───────────────
# 3000 chars per chunk = good balance of quality vs API usage
CHUNK_SIZE=3000
CHUNK_OVERLAP=300
MIN_CHUNK_SIZE=80

# ── Consensus ────────────────────────────────────────────────
VOTE_THRESHOLD=1
CONF_THRESHOLD=0.35
EDGE_CONF_THRESHOLD=0.35

# ── Agent settings ────────────────────────────────────────────
MAX_RETRIES=3
CHUNK_TIMEOUT=120
MAX_PROCESSING_WAIT=300
